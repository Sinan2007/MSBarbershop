@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<style>
    .login-page {
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 15px;
    }

    .login-card {
        width: 100%;
        max-width: 460px;
        background: #111827;
        border: 1px solid #2a2f3a;
        border-radius: 18px;
        padding: 35px 30px;
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.22);
    }

    .login-title {
        text-align: center;
        color: white;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .login-subtitle {
        text-align: center;
        color: #9ca3af;
        margin-bottom: 28px;
    }

    .form-label {
        color: #f3f4f6;
        font-weight: 500;
    }

    .form-control {
        background-color: #0b1220;
        border: 1px solid #374151;
        color: white;
        border-radius: 10px;
        padding: 12px 14px;
    }

        .form-control:focus {
            background-color: #0b1220;
            color: white;
            border-color: #d4af37;
            box-shadow: 0 0 0 0.2rem rgba(212, 175, 55, 0.15);
        }

    .form-check-label {
        color: #d1d5db;
    }

    .btn-login {
        width: 100%;
        background-color: #d4af37;
        color: black;
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-login:hover {
            background-color: #e6c14a;
            color: black;
        }

    .login-links {
        text-align: center;
        margin-top: 22px;
    }

        .login-links a {
            color: #d4af37;
            text-decoration: none;
        }

            .login-links a:hover {
                text-decoration: underline;
            }

    .external-box {
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid #2f3642;
    }

    .external-title {
        text-align: center;
        color: #9ca3af;
        margin-bottom: 15px;
    }

    .btn-external {
        width: 100%;
        margin-bottom: 10px;
        border-radius: 10px;
    }

    .text-danger {
        font-size: 0.9rem;
    }
</style>

<div class="container login-page">
    <div class="login-card">

        <div class="text-center mb-3">
            <img src="~/images/MS logo.png"
                 alt="MS Barbershop"
                 style="height: 70px;" />
        </div>

        <h2 class="login-title">Log in</h2>
        <p class="login-subtitle">Sign in to your MS Barbershop account</p>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email"
                       class="form-control"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="Enter your email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label asp-for="Input.Password" class="form-label mb-0">Password</label>
                    <a id="forgot-password" asp-page="./ForgotPassword">Forgot password?</a>
                </div>
                <input asp-for="Input.Password"
                       class="form-control"
                       autocomplete="current-password"
                       aria-required="true"
                       placeholder="Enter your password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>

            <button id="login-submit" type="submit" class="btn btn-login">
                Log in
            </button>

            <div class="login-links">
                <p class="mb-2">
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                        Create a new account
                    </a>
                </p>
                <p class="mb-0">
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">
                        Resend email confirmation
                    </a>
                </p>
            </div>
        </form>

        @{
            if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="external-box">
                    <p class="external-title">Or continue with</p>

                    <form id="external-account"
                          asp-page="./ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit"
                                    class="btn btn-outline-light btn-external"
                                    name="provider"
                                    value="@provider.Name"
                                    title="Log in using your @provider.DisplayName account">
                                @provider.DisplayName
                            </button>
                        }
                    </form>
                </div>
            }
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}