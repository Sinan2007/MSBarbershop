@model MSBarbershop.Core.ViewModels.Home.HomeIndexViewModel


@{
    ViewData["Title"] = "Home Page";
}

<style>
    /* Custom Barbershop Theme */
    :root {
        --accent-gold: #d4af37;
        --dark-bg: #121212;
    }

    .hero-section {
        background: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)), url('/images/MSBarbershopHomeImage.jpg'); /* Ensure this path is correct */
        background-size: cover;
        background-position: center;
        height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .btn-gold {
        background-color: var(--accent-gold);
        color: black;
        font-weight: bold;
        border: none;
        padding: 15px 40px;
        transition: 0.3s;
    }

        .btn-gold:hover {
            background-color: #f1c40f;
            transform: scale(1.05);
            color: black;
        }

    .section-title {
        font-family: 'Playfair Display', serif; /* Optional: Link this font in _Layout */
        color: var(--accent-gold);
        text-align: center;
        margin-bottom: 50px;
    }

    .feature-card {
        background: #1e1e1e;
        border: 1px solid #333;
        padding: 40px;
        transition: 0.3s;
        color: #eee;
    }

        .feature-card:hover {
            border-color: var(--accent-gold);
        }

    .feature-icon {
        color: var(--accent-gold);
        font-size: 3rem;
        margin-bottom: 20px;
    }
</style>

<!-- Hero Section -->
<div class="hero-section text-center mb-5">
    <div class="container">
        <h1 class="display-1 fw-bold">MS BARBERSHOP</h1>
        <p class="lead mb-4">Precision. Style. Tradition.</p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a asp-controller="Reservations" asp-action="Create" class="btn btn-gold btn-lg px-5">Book Appointment</a>
        </div>
    </div>
</div>

<!-- Services / Features Section -->
<h2 class="section-title mt-5 text-center">OUR SERVICES</h2>

<div class="row g-4 mt-3">

    @foreach (var service in Model.Services)
    {
        <div class="col-md-4">
            <div class="why-card service-card h-100 text-center">

                <div class="why-icon">✂</div>

                <h4 class="why-title">@service.Name</h4>

                <p class="why-text">
                    @service.Description
                </p>

                <div class="service-info mt-3">
                    <span class="service-price">$@service.Price</span>
                    <span class="service-duration">@service.DurationMinutes min</span>
                </div>

            </div>
        </div>
    }

</div>

<section class="why-us-section py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">WHY CHOOSE US?</h2>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="why-card h-100 text-center">
                    <div class="why-icon">✂</div>
                    <h4 class="why-title">Professional Barbers</h4>
                    <p class="why-text">
                        Our team combines precision, experience and modern barbering style
                        to give every client the best result.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="why-card h-100 text-center">
                    <div class="why-icon">★</div>
                    <h4 class="why-title">Premium Experience</h4>
                    <p class="why-text">
                        We focus on comfort, atmosphere and attention to detail so every visit
                        feels more than just a haircut.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="why-card h-100 text-center">
                    <div class="why-icon">🕒</div>
                    <h4 class="why-title">Easy Online Booking</h4>
                    <p class="why-text">
                        Book your appointment quickly, choose your barber and service,
                        and manage your reservations anytime.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="working-hours-section py-5">
    <div class="container">
        <div class="hours-box text-center">
            <h2 class="section-title mb-4">WORKING HOURS</h2>

            <div class="hours-list">
                <p><strong>Monday - Friday:</strong> 09:00 - 18:00</p>
                <p><strong>Saturday:</strong> 10:00 - 16:00</p>
                <p><strong>Sunday:</strong> Closed</p>
                <p><strong>Address:</strong> Mazalat 2 Kazanlak</p>
                <p><a asp-controller="Home" asp-action="AboutUs" class="btn btn-gold btn-lg px-5">About Us</a></p>
            </div>
        </div>
    </div>
</section>

<h2 class="section-title mt-5 text-center">OUR BARBERS</h2>

<div class="row justify-content-center g-4" style="max-width: 1000px; margin: 0 auto;">

    @foreach (var barber in Model.Barbers)
    {
        <div class="col-md-4">
            <div class="why-card h-100 text-center">

                <img src="@barber.ImageUrl"
                     class="img-fluid rounded mb-3"
                     style="height:250px; width:100%; object-fit:cover; object-position:center top;" />

                <h4 class="why-title">@barber.FullName</h4>

                <p class="why-text">
                    @barber.Description
                </p>

                <a asp-controller="Reservations"
                   asp-action="Create"
                   class="btn btn-outline-light mt-2">
                    Book
                </a>

                <a asp-controller="Barbers"
                   asp-action="Details"
                   asp-route-id="@barber.Id"
                   class="btn btn-outline-light mt-2">
                    More Info
                </a>
            </div>
        </div>
    }
</div>


<section class="reviews-section py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">WHAT OUR CLIENTS SAY</h2>

        @if (Model.Reviews != null && Model.Reviews.Any())
        {
            <div class="row justify-content-center g-4">
                @foreach (var review in Model.Reviews)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="review-card h-100">
                            <div class="review-quote">“</div>

                            <p class="review-text">
                                @review.Content
                            </p>

                            <div class="review-rating mb-3">
                                @for (int i = 0; i < review.Rating; i++)
                                {
                                    <span>★</span>
                                }
                            </div>

                            <div class="review-user">
                                <span class="review-user-line"></span>
                                <h5>@review.User.FirstName @review.User.LastName</h5>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-center text-muted">No reviews yet.</p>
        }
    </div>
</section>




