@model IEnumerable<MSBarbershop.Data.Entities.Service>


@{
    ViewData["Title"] = "Home Page";
}

<style>
    /* Custom Barbershop Theme */
    :root {
        --accent-gold: #d4af37;
        --dark-bg: #121212;
    }

    .hero-section {
        background: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)), url('/images/MSBarbershopHomeImage.jpg'); /* Ensure this path is correct */
        background-size: cover;
        background-position: center;
        height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .btn-gold {
        background-color: var(--accent-gold);
        color: black;
        font-weight: bold;
        border: none;
        padding: 15px 40px;
        transition: 0.3s;
    }

        .btn-gold:hover {
            background-color: #f1c40f;
            transform: scale(1.05);
            color: black;
        }

    .section-title {
        font-family: 'Playfair Display', serif; /* Optional: Link this font in _Layout */
        color: var(--accent-gold);
        text-align: center;
        margin-bottom: 50px;
    }

    .feature-card {
        background: #1e1e1e;
        border: 1px solid #333;
        padding: 40px;
        transition: 0.3s;
        color: #eee;
    }

        .feature-card:hover {
            border-color: var(--accent-gold);
        }

    .feature-icon {
        color: var(--accent-gold);
        font-size: 3rem;
        margin-bottom: 20px;
    }
</style>

<!-- Hero Section -->
<div class="hero-section text-center mb-5">
    <div class="container">
        <h1 class="display-1 fw-bold">MS BARBERSHOP</h1>
        <p class="lead mb-4">Precision. Style. Tradition.</p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a asp-controller="Reservations" asp-action="Create" class="btn btn-gold btn-lg px-5">Book Appointment</a>
        </div>
    </div>
</div>

<!-- Services / Features Section -->
<h2 class="section-title mt-5">OUR SERVICES</h2>

<div class="row">

    @foreach (var service in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card bg-dark text-white text-center p-4 h-100">

                <h3>@service.Name</h3>

                <p class="text-muted">
                    @service.Description
                </p>

                <h5 class="fw-bold mt-3">
                    $@service.Price
                </h5>

            </div>
        </div>
    }

</div>

<h2 class="section-title mt-5">OUR BARBERS</h2>

<div class="row justify-content-center" style="max-width: 900px; margin: 0 auto;">


    @foreach (var barber in (IEnumerable<MSBarbershop.Data.Entities.Barber>)ViewBag.Barbers)
    {
        <div class="col-md-6 mb-4">


            <div class="card bg-dark text-white text-center p-3 h-100">

                <img src="@barber.ImageUrl"
                     class="img-fluid rounded mb-3"
                     style="height:250px; object-fit:cover;" />

                <h4>@barber.FullName</h4>

                <p class="text-muted">
                    @barber.Description
                </p>

                <a asp-controller="Reservations"
                   asp-action="Create"
                   class="btn btn-outline-light mt-2">
                    Book
                </a>

                <a asp-controller="Barbers"
                   asp-action="Details"
                   asp-route-id="@barber.Id"
                   class="btn btn-outline-light mt-2">
                    @barber.FullName's info
                </a>

            </div>
        </div>
    }
</div>

<div class="text-center mt-3">
    <a asp-controller="Home" asp-action="OurBarbers" class="btn btn-gold">
        View All Barbers
    </a>
</div>


<h2 class="section-title mt-5">WHAT OUR CLIENTS SAY</h2>

<div class="row">

    <div class="col-md-4 mb-4">
        <div class="feature-card text-center">
            <p>"Best haircut I've ever had!"</p>
            <h5 class="mt-3">⭐⭐⭐⭐⭐</h5>
            <small>- Stanimir Zhelev</small>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="feature-card text-center">
            <p>"Professional barbers and great atmosphere."</p>
            <h5 class="mt-3">⭐⭐⭐⭐⭐</h5>
            <small>- Georgi Petrov</small>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="feature-card text-center">
            <p>"Always leaving fresh 💯"</p>
            <h5 class="mt-3">⭐⭐⭐⭐⭐</h5>
            <small>- Stoyan Dimitrov</small>
        </div>
    </div>

</div>




<!-- Working Hours / CTA -->
<div class="bg-dark text-white py-5 mt-5">
    <div class="container text-center">
        <h3>READY FOR A NEW LOOK?</h3>
        <p>Monday - Saturday: 09:00 - 18:00</p>
        <p>Sunday: CLOSED</p>
        <a asp-controller="Home" asp-action="AboutUs" class="btn btn-outline-light mt-3">Learn More About Us</a>
    </div>
</div>