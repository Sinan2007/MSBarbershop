@model IEnumerable<MSBarbershop.Data.Entities.Barber>

@{
    ViewData["Title"] = "Our Barbers";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Meet Our Professional Barbers</h1>
        <p class="lead text-muted">
            Skilled hands. Sharp vision. Perfect results.
        </p>
    </div>

    <div class="row g-4">
        @foreach (var barber in Model)
        {
            <div class="col-md-4">
                <div class="card barber-card">

                    <img src="@barber.ImageUrl" alt="@barber.FullName" />

                    <div class="card-body text-center">
                        <h4 class="card-title">@barber.FullName</h4>

                        <p class="card-text">
                            @barber.Description
                        </p>

                        <div class="barber-actions">
                            <a asp-controller="Barbers"
                               asp-action="Details"
                               asp-route-id="@barber.Id"
                               class="btn btn-dark">
                                @barber.FullName's info
                            </a>

                            <a asp-controller="Reservations"
                               asp-action="Create"
                               asp-route-id="@barber.Id"
                               class="btn btn-dark">
                                Book with @barber.FullName
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
