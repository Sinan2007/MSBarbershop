@model IEnumerable<MSBarbershop.Data.Entities.Review>

<div class="container mt-5">
    <h2 class="fw-bold mb-4">All Reviews</h2>

    @if (TempData["Review"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["Review"]
        </div>
    }   

    <div class="card shadow-lg border-0">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Client</th>
                        <th>Rating</th>
                        <th>Comment</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var review in Model)
                    {
                        <tr>
                            <td>@review.User.FirstName @review.User.LastName</td>
                            <td>@review.Rating / 5</td>
                            <td>@review.Content</td>
                            <td>@review.CreatedOn.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (review.IsApproved)
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (!review.IsApproved)
                                {
                                    <form asp-action="Approve" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@review.Id" />
                                        <button class="btn btn-sm btn-success">Show</button>
                                    </form>
                                }

                               
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>