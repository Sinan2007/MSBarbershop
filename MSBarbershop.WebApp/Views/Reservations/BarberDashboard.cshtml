@using MSBarbershop.WebApp.ViewModels.Reservation
@model MyReservationsPageViewModel

<div class="container mt-5">

    <h2 class="mb-4 fw-bold">My Schedule</h2>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-4" id="reservationTabs">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#upcoming">
                Upcoming
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#past">
                Past
            </button>
        </li>
    </ul>

    <div class="tab-content">

        <!-- 🔵 UPCOMING -->
        <div class="tab-pane fade show active" id="upcoming">
            <div class="row">
                @foreach (var r in Model.Upcoming)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-lg border-0">
                            <div class="card-body">

                                <h5 class="fw-bold">@r.ServiceName</h5>
                                <p class="text-muted">@r.BarberName</p>

                                <p>📅 @r.Date</p>
                                <p>⏰ @r.Time</p>

                                <span class="badge bg-warning text-dark">
                                    @r.Status
                                </span>

                                <!-- 🔥 BUTTONS -->
                                <div class="mt-3">

                                    <form asp-action="Complete" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button class="btn btn-success btn-sm">
                                            Complete
                                        </button>
                                    </form>

                                    <form asp-action="Cancel" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button class="btn btn-danger btn-sm">
                                            Cancel
                                        </button>
                                    </form>

                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ⚪ PAST -->
        <div class="tab-pane fade" id="past">
            <div class="row">
                @foreach (var r in Model.Past)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-lg border-0">
                            <div class="card-body">

                                <h5 class="fw-bold">@r.ServiceName</h5>
                                <p class="text-muted">@r.BarberName</p>

                                <p>📅 @r.Date</p>
                                <p>⏰ @r.Time</p>

                                <span class="badge
                                        @(r.Status.ToString() == "Completed" ? "bg-success" : "bg-danger")">
                                    @r.Status
                                </span>

                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

    </div>

</div>
