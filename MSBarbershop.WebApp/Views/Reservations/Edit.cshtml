@using MSBarbershop.Core.ViewModels.Reservation
@model EditReservationViewModel
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-body p-4">

                    <h3 class="text-center mb-4 fw-bold">
                        Edit Your Reservation 
                    </h3>
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <!-- Barber -->
                        <div class="mb-3">
                            <label asp-for="BarberId" class="form-label">Barber</label>
                            <select asp-for="BarberId"
                                    class="form-select"
                                    asp-items="Model.Barbers">
                            </select>
                            <span asp-validation-for="BarberId" class="text-danger"></span>
                        </div>
                        <!-- Service -->
                        <div class="mb-3">
                            <label asp-for="ServiceId" class="form-label">Service</label>
                            <select asp-for="ServiceId"
                                    class="form-select"
                                    asp-items="Model.Services">
                            </select>
                            <span asp-validation-for="ServiceId" class="text-danger"></span>
                        </div>
                        <!-- Date -->
                        <div class="mb-3">
                            <label asp-for="Date" class="form-label">Date</label>
                            <input asp-for="Date" type="date" class="form-control" min="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="Date" class="text-danger"></span>
                        </div>
                        <!-- Time -->
                        <div class="mb-3">
                            <label asp-for="Time" class="form-label">Time</label>
                            <input asp-for="Time" type="time" class="form-control" />
                            <span asp-validation-for="Time" class="text-danger"></span>
                        </div>
                        <!-- Buttons -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-dark btn-lg">
                                Save Changes
                            </button>
                            <a asp-action="MyReservations" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}