@using Microsoft.AspNetCore.Identity
@using MSBarbershop.Data.Entities
@inject UserManager<User> UserManager

@{
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
    User? currentUser = null;

    if (isAuthenticated)
    {
        currentUser = await UserManager.GetUserAsync(User);
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MSBarbershop.WebApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MSBarbershop.WebApp.styles.css" asp-append-version="true" />

    <style>
        .custom-navbar {
            background: rgba(20, 20, 20, 0.92);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            box-shadow: 0 2px 14px rgba(0, 0, 0, 0.18);
            padding-top: 12px;
            padding-bottom: 12px;
        }

        .main-nav-center .nav-link {
            color: white !important;
            font-size: 1.15rem;
            font-weight: 500;
            margin: 0 10px;
            transition: color 0.25s ease;
        }

            .main-nav-center .nav-link:hover {
                color: #d4af37 !important;
            }

        .booking-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #d4af37;
            border-radius: 999px;
            padding: 10px 22px !important;
            color: #d4af37 !important;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.25s ease;
            white-space: nowrap;
            margin-right: 12px;
        }

            .booking-btn:hover {
                background-color: #d4af37;
                color: black !important;
            }

        .auth-link {
            color: white !important;
            font-size: 1.05rem;
            font-weight: 500;
            margin-left: 12px;
            text-decoration: none;
            transition: color 0.25s ease;
        }

            .auth-link:hover {
                color: #d4af37 !important;
            }

        .profile-link {
            color: white !important;
            font-size: 1.05rem;
            font-weight: 500;
            text-decoration: none;
        }

            .profile-link:hover {
                color: #d4af37 !important;
            }

        .custom-profile-dropdown {
            background-color: #1c1f26;
            border: 1px solid #333;
            border-radius: 12px;
            min-width: 270px;
            padding: 10px 0;
        }

            .custom-profile-dropdown .dropdown-header {
                color: white;
                padding: 12px 18px;
                line-height: 1.6;
            }

            .custom-profile-dropdown .dropdown-item {
                color: white;
                padding: 10px 18px;
            }

                .custom-profile-dropdown .dropdown-item:hover {
                    background-color: #2a2f38;
                    color: #d4af37;
                }

            .custom-profile-dropdown .dropdown-divider {
                border-color: #333;
            }

        .logout-btn {
            background: none;
            border: none;
            width: 100%;
            text-align: left;
            color: white;
            padding: 10px 18px;
        }

            .logout-btn:hover {
                background-color: #2a2f38;
                color: #d4af37;
            }

        body {
            padding-top: 90px;
        }

        @@media (max-width: 991.98px) {
            .booking-btn {
                margin-right: 0;
                margin-bottom: 10px;
            }

            .auth-link {
                margin-left: 0;
                margin-top: 10px;
                display: inline-block;
            }

            .main-nav-center .nav-link {
                margin: 8px 0;
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg custom-navbar fixed-top">
            <div class="container">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/images/MS logo.png"
                         alt="MS Barbershop"
                         height="55"
                         class="rounded" />
                </a>

                <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- CENTER NAV -->
                    <ul class="navbar-nav mx-auto main-nav-center align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="AboutUs">About Us</a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reservations" asp-action="AllReservations">Reservations</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Services" asp-action="Index">Services</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Barbers" asp-action="Index">Barbers</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="WorkSchedules" asp-action="Index">Schedules</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reviews" asp-action="AllReviews">Reviews</a>
                            </li>
                        }
                        else if (User.IsInRole("Barber"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reservations" asp-action="BarberDashboard">My Dashboard</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="OurBarbers">Our Barbers</a>
                            </li>
                        }
                    </ul>

                    <!-- RIGHT NAV -->
                    <div class="d-flex flex-column flex-lg-row align-items-lg-center ms-lg-auto">

                        @if (!User.IsInRole("Admin") && !User.IsInRole("Barber"))
                        {
                            <a class="booking-btn"
                               asp-controller="Reservations"
                               asp-action="Create">
                                Make a reservation →
                            </a>
                        }

                        @if (!isAuthenticated)
                        {
                            <a class="auth-link"
                               asp-area="Identity"
                               asp-page="/Account/Register">
                                Register
                            </a>

                            <a class="auth-link"
                               asp-area="Identity"
                               asp-page="/Account/Login">
                                Log in
                            </a>
                        }
                        else
                        {
                            <div class="dropdown">
                                <a class="profile-link dropdown-toggle"
                                   href="#"
                                   id="profileDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Profile
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end custom-profile-dropdown"
                                    aria-labelledby="profileDropdown">
                                    <li class="dropdown-header">
                                        <strong>@currentUser?.FirstName @currentUser?.LastName</strong><br />
                                        <small>@currentUser?.Email</small><br />
                                        <small>@currentUser?.PhoneNumber</small>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    @if (User.IsInRole("Customer"))
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Reservations"
                                               asp-action="MyReservations">
                                                My reservations
                                            </a>
                                        </li>
                                    }

                                    @if (User.IsInRole("Barber"))
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Reservations"
                                               asp-action="BarberDashboard">
                                                My dashboard
                                            </a>
                                        </li>
                                    }

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Reservations"
                                               asp-action="AllReservations">
                                                Admin panel
                                            </a>
                                        </li>
                                    }

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Profile"
                                           asp-action="Index">
                                            Account settings
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    <li>
                                        <form asp-area="Identity"
                                              asp-page="/Account/Logout"
                                              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                                              method="post" class="m-0">
                                            <button type="submit" class="logout-btn">
                                                Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container d-flex justify-content-center">
            &copy; 2025 - MSBarbershop 
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>