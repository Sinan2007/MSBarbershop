<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MSBarbershop.WebApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MSBarbershop.WebApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-dark border-bottom box-shadow mb-3" >
            <div class="container-fluid">
                <a class="navbar-brand ms-auto" asp-controller="Home" asp-action="Index">
                    <img src="~/images/MS logo.png"
                         alt="MS Barbershop"
                         height="50"
                         class="d-inline-block align-text-top">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @{
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
}
               <div class="navbar-collapse collapse @(isAuthenticated ? "justify-content-center" : "justify-content-start")">
                   <ul class="navbar-nav @(isAuthenticated ? "mx-auto" : "")">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="AboutUs">About Us</a>
                        </li>
                        
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Reservations" asp-action="AllReservations">Reservations</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Services" asp-action="Index">Services</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Barbers" asp-action="Index">Barbers</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="WorkSchedules" asp-action="Index">Schedules</a>
                            </li>
                            <li class="nav-item">
    <a class="nav-link text-white" asp-controller="Reviews" asp-action="AllReviews">Reviews</a>
</li>
                        }
                        else if (User.IsInRole("Barber"))
                        {
                             <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Reservations" asp-action="BarberDashboard">My Dashboard</a>
                            </li>
                        }

                        else if (User.IsInRole("Customer"))
                        {
                             <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Reservations" asp-action="MyReservations">My reservations</a>
                            </li>

                              <li class="nav-item">
                                <a class="nav-link booking-btn" asp-controller="Reservations" asp-action="Create">
    Make a reservation →
</a>
                            </li>
                        }
                        
                          
                           
                        }

                    </ul>
                   <div class="ms-auto">
    <partial name="_LoginPartial" />
</div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container mt-3">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container d-flex justify-content-center text-black-50">
            &copy; 2025 - MSBarbershop
        </div>
    </footer>


   

   
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
